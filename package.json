{
  "name": "vue-project",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-s build-main copy-spines",
    "build-main": "run-p type-check \"build-only {@}\" --",
    "copy-spines": "node scripts/copy-spines.js",
    "preview": "pnpm run build-only && wrangler dev",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "eslint . --fix",
    "deploy": "pnpm run build-only && wrangler deploy"
  },
  "dependencies": {
    "@esotericsoftware/spine-player": "4.1.55",
    "@tailwindcss/vite": "^4.1.10",
    "jszip": "^3.10.1",
    "pinia": "^3.0.1",
    "tailwindcss": "^4.1.10",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.42.1",
    "@tsconfig/node22": "^22.0.1",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-vue": "^5.2.3",
    "@vue/eslint-config-typescript": "^14.5.0",
    "@vue/tsconfig": "^0.7.0",
    "eslint": "^9.22.0",
    "eslint-plugin-vue": "~10.0.0",
    "jiti": "^2.4.2",
    "npm-run-all2": "^7.0.2",
    "typescript": "~5.8.0",
    "vite": "^6.2.4",
    "vue-tsc": "^2.2.8",
    "wrangler": "^4.103.0"
  }
}
